# Sao chép file này thành .env (hoặc đặt biến môi trường trong cấu hình MCP client).

# Cách 1: đường dẫn tới file JSON khóa service account (khuyến nghị)
FIREBASE_SERVICE_ACCOUNT_PATH=./service-account.json

# Cách 2: dán thẳng nội dung JSON khóa (1 dòng) — dùng khi không tiện để file
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"zitthenkne",...}

# Cách 3: chuẩn Google Application Default Credentials
# GOOGLE_APPLICATION_CREDENTIALS=/duong/dan/service-account.json

# Project ID (mặc định "zitthenkne" nếu bỏ trống)
FIREBASE_PROJECT_ID=zitthenkne
