{
  "name": "zitthenkne-mcp-server",
  "version": "1.0.0",
  "description": "MCP server cho web app học tập Zitthenkne (Firebase Firestore). Cho phép agent tra cứu, tạo, sửa, xóa bộ đề trắc nghiệm và xem thống kê.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "zitthenkne-mcp-server": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "firebase-admin": "^12.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
